{
  "title": "90-Day Farsi Vancouver YouTube Roadmap",
  "niche": "Farsi video essays about Vancouver (urbanism, transit, housing, newcomer life)",
  "style_target": "About Here / The B1M — research depth, dry humor, strong cold open",
  "publish_cadence": "1 long-form every 2 weeks + 1 Short per week minimum",
  "weeks_detailed": [
    {
      "week": 1,
      "phase": "foundations",
      "theme": "Pick niche + study hooks",
      "goals": [
        "Choose Farsi Vancouver urbanism as primary niche",
        "Watch 10 style_benchmark videos",
        "Save 20 hooks to swipe file"
      ],
      "daily": [
        {
          "day": 1,
          "tasks": [
            "Read playbook hook bank (top 20)",
            "Write 3 niche sentences: who you serve",
            "Set up channel name + banner draft"
          ]
        },
        {
          "day": 2,
          "tasks": [
            "Study 3 About Here teardown samples",
            "Note hook + title pattern",
            "Pick first video topic from idea list"
          ]
        },
        {
          "day": 3,
          "tasks": [
            "Outline video 1 using template beats",
            "Record 60-sec test on phone",
            "Watch back — pace, lighting, audio"
          ]
        },
        {
          "day": 4,
          "tasks": [
            "Improve audio (mic or quiet room)",
            "Practice hook 5 times without teleprompter",
            "Draft thumbnail text (3 words max)"
          ]
        },
        {
          "day": 5,
          "tasks": [
            "Research video 1 (3 sources)",
            "Collect B-roll list (10 shots)",
            "Write script bullet points only"
          ]
        },
        {
          "day": 6,
          "tasks": [
            "Record A-roll (hook + 3 main points)",
            "Don't edit yet",
            "Rest voice"
          ]
        },
        {
          "day": 7,
          "tasks": [
            "Weekly review: what felt natural?",
            "Adjust week 2 plan",
            "Post nothing yet — polish first"
          ]
        }
      ]
    },
    {
      "week": 2,
      "phase": "foundations",
      "theme": "First edit + publish",
      "goals": [
        "Publish video 1",
        "Learn basic AI-assisted edit workflow"
      ],
      "daily": [
        {
          "day": 8,
          "tasks": [
            "Import footage; cut obvious mistakes",
            "Add 3 title cards in Farsi",
            "Music bed — low volume"
          ]
        },
        {
          "day": 9,
          "tasks": [
            "Use AI for rough cut or captions (CapCut/Descript)",
            "Check first 30s retention feel",
            "Export draft"
          ]
        },
        {
          "day": 10,
          "tasks": [
            "Thumbnail in Canva",
            "Title A/B: write 2 options",
            "Description + 5 tags in Farsi"
          ]
        },
        {
          "day": 11,
          "tasks": [
            "Publish video 1",
            "Share in 1 Farsi Vancouver group (not spammy)",
            "Log analytics baseline"
          ]
        },
        {
          "day": 12,
          "tasks": [
            "Read comments; reply to all",
            "Note drop-off timestamp",
            "Plan video 2 topic"
          ]
        },
        {
          "day": 13,
          "tasks": [
            "Shorts clip from video 1 (30–45s)",
            "Hook must work without context",
            "Publish Short"
          ]
        },
        {
          "day": 14,
          "tasks": [
            "Week review: views, CTR, retention",
            "One improvement for video 2",
            "Rest or light B-roll shoot"
          ]
        }
      ]
    },
    {
      "week": 3,
      "phase": "skills",
      "theme": "On-camera confidence",
      "goals": [
        "Teleprompter-free delivery",
        "Publish video 2"
      ],
      "daily": [
        {
          "day": 15,
          "tasks": [
            "TED on-camera: 15 min study",
            "Mirror practice — 2 min hook",
            "Bullet-point script only"
          ]
        },
        {
          "day": 16,
          "tasks": [
            "Record video 2 A-roll",
            "3 takes max per section",
            "B-roll same day if possible"
          ]
        },
        {
          "day": 17,
          "tasks": [
            "Edit video 2 faster than video 1",
            "Target 50% less time",
            "Captions in Farsi"
          ]
        },
        {
          "day": 18,
          "tasks": [
            "Publish video 2",
            "Pin comment with question",
            "Engage 30 min after publish"
          ]
        },
        {
          "day": 19,
          "tasks": [
            "Analytics: compare V1 vs V2 retention",
            "Update hook swipe file",
            "Outline video 3"
          ]
        },
        {
          "day": 20,
          "tasks": [
            "Batch B-roll for videos 3–4",
            "Photos of Vancouver streets/transit",
            "Organize folders"
          ]
        },
        {
          "day": 21,
          "tasks": [
            "Weekly review",
            "Schedule next 2 publish dates",
            "Break"
          ]
        }
      ]
    },
    {
      "week": 4,
      "phase": "skills",
      "theme": "AI workflow + consistency",
      "goals": [
        "Repeatable edit pipeline",
        "2 videos/month minimum cadence"
      ],
      "daily": [
        {
          "day": 22,
          "tasks": [
            "Document your edit steps (checklist)",
            "One AI tool for captions/thumbnails",
            "Don't add more tools"
          ]
        },
        {
          "day": 23,
          "tasks": [
            "Script video 3 with About Here template",
            "Cold open written last",
            "Peer review hook (friend)"
          ]
        },
        {
          "day": 24,
          "tasks": [
            "Record + edit video 3",
            "Publish or schedule"
          ]
        },
        {
          "day": 25,
          "tasks": [
            "SEO: Farsi + English keywords in description",
            "Chapter markers",
            "End screen to video 1"
          ]
        },
        {
          "day": 26,
          "tasks": [
            "Outreach: comment on 5 Vancouver/Farsi channels",
            "Genuine, not promo"
          ]
        },
        {
          "day": 27,
          "tasks": [
            "Shorts from video 3",
            "Test 'question hook' vs 'statement hook'"
          ]
        },
        {
          "day": 28,
          "tasks": [
            "Month 1 retrospective",
            "Sub count, hours spent, joy level",
            "Adjust month 2 goals"
          ]
        }
      ]
    }
  ],
  "phase_plan": [
    {
      "days": "29-42",
      "phase": "niche",
      "theme": "Double down on Vancouver Farsi essays",
      "weekly_cadence": [
        "Mon: research + outline",
        "Tue: script bullets",
        "Wed: record",
        "Thu: edit",
        "Fri: thumbnail + publish prep",
        "Sat: publish + engage",
        "Sun: analytics + one Short"
      ]
    },
    {
      "days": "43-56",
      "phase": "niche",
      "theme": "Collaborate + community",
      "weekly_cadence": [
        "Interview 1 local Persian business or commuter",
        "Cross-promote with small Farsi creator",
        "2 videos this fortnight"
      ]
    },
    {
      "days": "57-70",
      "phase": "monetization",
      "theme": "Audience + revenue prep",
      "weekly_cadence": [
        "Apply for YPP when eligible",
        "Media kit draft",
        "List 10 Vancouver brands for future sponsors"
      ]
    },
    {
      "days": "71-90",
      "phase": "scaling",
      "theme": "Systemize",
      "weekly_cadence": [
        "Batch 2 outlines",
        "Template thumbnails",
        "Monthly live or community post",
        "Review top 5 hooks that worked"
      ]
    }
  ],
  "daily_checklist_template": {
    "every_publish_day": [
      "Hook works in first 5 seconds (read aloud)",
      "Title under 60 chars; curiosity + place name",
      "Thumbnail readable on phone",
      "Farsi captions uploaded",
      "Pinned comment with question",
      "Reply to comments within 24h"
    ],
    "every_week": [
      "Check retention graph for last video",
      "Add 1 hook to swipe file",
      "One Short from long-form",
      "30 min genuine community engagement"
    ]
  },
  "milestones": [
    {
      "day": 11,
      "milestone": "First video published"
    },
    {
      "day": 28,
      "milestone": "3 videos + 4 Shorts; repeatable workflow"
    },
    {
      "day": 60,
      "milestone": "8+ videos; clear best-performing topic"
    },
    {
      "day": 90,
      "milestone": "12+ videos; monetization path chosen"
    }
  ]
}